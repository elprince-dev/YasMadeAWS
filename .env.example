# Supabase credentials
# Get these from your Supabase project settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Email API (AWS API Gateway endpoint deployed by CDK EmailStack)
# After CDK deployment, find this in the stack outputs as the HttpApi URL
VITE_EMAIL_API_URL=https://your-api-id.execute-api.us-east-1.amazonaws.com

# CodePipeline (CI/CD)
# Create a CodeStar connection in AWS Console → Developer Tools → Connections
CODESTAR_CONNECTION_ARN=arn:aws:codeconnections:us-east-1:123456789012:connection/your-connection-id
GITHUB_OWNER=your-github-username
GITHUB_REPO=your-repo-name

